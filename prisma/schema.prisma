generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Linha agregada do CSV INEP (uma linha = curso × IES × modalidade com contagens por ano).
/// Colunas alinhadas ao DDL criado no Supabase (identificadores com maiúsculas / espaços).
model MatriculaLinha {
  id                      Int     @id @default(autoincrement())
  estado                  String? @map("Estado")
  cidade                  String? @map("Cidade")
  ies                     String? @map("IES")
  sigla                   String? @map("Sigla")
  organizacao             String? @map("Organização")
  categoriaAdministrativa String? @map("Categoria Administrativa")
  /// TEXT no banco; no seed usamos "Sim" / "Não" para filtrar rankings por setor.
  publica                 String? @map("Pública")
  nomeCurso               String? @map("Nome do Curso")
  nomeDetalhadoCurso      String? @map("Nome Detalhado do Curso")
  modalidade              String? @map("Modalidade")
  grau                    String? @map("Grau")
  y2014                   Int?    @map("y2014")
  y2015                   Int?    @map("y2015")
  y2016                   Int?    @map("y2016")
  y2017                   Int?    @map("y2017")
  y2018                   Int?    @map("y2018")
  y2019                   Int?    @map("y2019")
  y2020                   Int?    @map("y2020")
  y2021                   Int?    @map("y2021")
  y2022                   Int?    @map("y2022")

  @@map("matricula_linha")
}
